{
  "name": "Magazine",
  "slug": "magazine",
  "version": "1.0.0",
  "description": "杂志风格主题 - 网格布局、特色图片展示、多栏目支持，适合新闻和杂志网站",
  "author": "FastBlog Team",
  "author_url": "https://athenavi.github.io",
  "plugin_url": "https://athenavi.github.io/themes/magazine",
  "category": "theme",
  "icon": "📰",
  "screenshot": "screenshot.svg",
  "license": "MIT",
  "tags": ["magazine", "news", "grid", "responsive", "featured-image"],
  "requires": {"fastblog": ">=1.0.0"},
  "supports": ["custom-logo", "custom-header", "featured-image", "post-thumbnails", "comments", "widgets", "multi-column", "sticky-posts", "dark-mode"],
  "settings_schema": {
    "colors": {
      "type": "group", "label": "颜色方案",
      "fields": {
        "primary": {"type": "color", "label": "主色调", "default": "#dc2626"},
        "secondary": {"type": "color", "label": "次要色", "default": "#1f2937"},
        "accent": {"type": "color", "label": "强调色", "default": "#f59e0b"},
        "background": {"type": "color", "label": "背景色", "default": "#ffffff"},
        "foreground": {"type": "color", "label": "前景色", "default": "#111827"}
      }
    },
    "layout": {
      "type": "group", "label": "布局设置",
      "fields": {
        "sidebar_position": {"type": "select", "label": "侧边栏位置", "options": [{"value": "left", "label": "左侧"}, {"value": "right", "label": "右侧"}, {"value": "none", "label": "无"}], "default": "right"},
        "content_width": {"type": "select", "label": "内容宽度", "options": [{"value": "max-w-4xl", "label": "中"}, {"value": "max-w-5xl", "label": "宽"}, {"value": "max-w-7xl", "label": "超宽"}], "default": "max-w-7xl"},
        "show_sidebar": {"type": "boolean", "label": "显示侧边栏", "default": true},
        "grid_columns": {"type": "select", "label": "网格列数", "options": [{"value": 2, "label": "2列"}, {"value": 3, "label": "3列"}, {"value": 4, "label": "4列"}], "default": 3}
      }
    },
    "typography": {
      "type": "group", "label": "排版设置",
      "fields": {
        "font_family": {"type": "text", "label": "正文字体", "default": "Merriweather, Georgia, serif"},
        "heading_font": {"type": "text", "label": "标题字体", "default": "Montserrat, sans-serif"},
        "font_size": {"type": "text", "label": "字号", "default": "16px"},
        "line_height": {"type": "number", "label": "行高", "default": 1.8}
      }
    },
    "features": {
      "type": "group", "label": "功能开关",
      "fields": {
        "show_featured_posts": {"type": "boolean", "label": "显示精选文章", "default": true},
        "show_category_sections": {"type": "boolean", "label": "显示分类区块", "default": true},
        "sticky_header": {"type": "boolean", "label": "粘性导航栏", "default": true}
      }
    }
  }
}
