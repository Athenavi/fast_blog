{
  "id": 0,
  "name": "全文搜索引擎",
  "slug": "fulltext-search",
  "version": "1.0.0",
  "description": "基于 Meilisearch 的高性能全文搜索引擎，支持拼音搜索、模糊匹配、结果高亮等功能",
  "author": "FastBlog Team",
  "author_url": "https://fastblog.com",
  "plugin_url": "https://github.com/fastblog/plugins/fulltext-search",
  "icon": "search",
  "min_version": "1.0.0",
  "tags": [
    "search",
    "meilisearch",
    "fulltext",
    "performance"
  ],
  "category": "功能增强",
  "license": "MIT",
  "capabilities": [
    "article.index",
    "article.search",
    "settings.read",
    "settings.write"
  ],
  "dependencies": [],
  "settings": {
    "enabled": {
      "type": "boolean",
      "label": "启用搜索引擎",
      "default": true,
      "help_text": "是否启用 Meilisearch 全文搜索功能"
    },
    "host": {
      "type": "text",
      "label": "Meilisearch 服务器地址",
      "default": "http://localhost:7700",
      "help_text": "Meilisearch 服务器的 URL 地址"
    },
    "api_key": {
      "type": "password",
      "label": "API 密钥",
      "default": "",
      "help_text": "Meilisearch API 密钥（可选）"
    },
    "auto_sync": {
      "type": "boolean",
      "label": "自动同步",
      "default": true,
      "help_text": "文章发布/更新时自动同步到搜索引擎"
    },
    "index_on_publish": {
      "type": "boolean",
      "label": "发布时索引",
      "default": true,
      "help_text": "文章发布时自动创建索引"
    }
  }
}
