{
  "plugin_id": 0,
  "name": "FastBlog Cloud SSL",
  "slug": "cloud-ssl",
  "version": "1.0.0",
  "description": "SSL证书自动管理 - Let's Encrypt证书申请、续期、部署和监控",
  "author": "FastBlog Team",
  "category": "cloud",
  "tags": [
    "ssl",
    "letsencrypt",
    "certificate",
    "https"
  ],
  "min_version": "1.0.0",
  "dependencies": [
    "certbot"
  ],
  "settings_schema": {
    "general": {
      "title": "基础设置",
      "fields": [
        "enabled",
        "acme.email",
        "acme.server"
      ]
    },
    "validation": {
      "title": "验证配置",
      "fields": [
        "validation.method",
        "validation.dns_provider",
        "validation.dns_credentials"
      ]
    },
    "auto_renewal": {
      "title": "自动续期",
      "fields": [
        "auto_renewal.enabled",
        "auto_renewal.check_interval_days",
        "auto_renewal.renew_before_days"
      ]
    },
    "web_server": {
      "title": "Web服务器配置",
      "fields": [
        "web_server.type",
        "web_server.config_dir",
        "web_server.reload_command"
      ]
    },
    "monitoring": {
      "title": "监控告警",
      "fields": [
        "monitoring.enabled",
        "monitoring.alert_before_days",
        "monitoring.notification_channels"
      ]
    },
    "ssl_optimization": {
      "title": "SSL优化",
      "fields": [
        "ssl_optimization.enable_hsts",
        "ssl_optimization.hsts_max_age",
        "ssl_optimization.min_tls_version"
      ]
    }
  },
  "features": [
    "Let's Encrypt证书自动申请",
    "HTTP-01和DNS-01验证支持",
    "证书自动续期",
    "Nginx/Apache自动部署",
    "多域名和通配符证书",
    "证书过期监控和告警",
    "证书备份管理",
    "HSTS和SSL优化配置"
  ],
  "api_endpoints": [
    {
      "path": "/api/v2/cloud/ssl/request",
      "method": "POST",
      "description": "申请SSL证书"
    },
    {
      "path": "/api/v2/cloud/ssl/renew/{domain}",
      "method": "POST",
      "description": "续期证书"
    },
    {
      "path": "/api/v2/cloud/ssl/status/{domain}",
      "method": "GET",
      "description": "查询证书状态"
    },
    {
      "path": "/api/v2/cloud/ssl/list",
      "method": "GET",
      "description": "列出所有证书"
    },
    {
      "path": "/api/v2/cloud/ssl/deploy/{domain}",
      "method": "POST",
      "description": "部署证书到服务器"
    }
  ]
}
