{
  "plugin_id": 0,
  "name": "FastBlog Cloud CDN",
  "slug": "cloud-cdn",
  "version": "1.0.0",
  "description": "多云CDN管理服务 - 支持Cloudflare/阿里云/腾讯云,提供智能缓存策略和URL优化",
  "author": "FastBlog Team",
  "category": "cloud",
  "tags": [
    "cdn",
    "cache",
    "optimization",
    "performance"
  ],
  "min_version": "1.0.0",
  "dependencies": [],
  "settings_schema": {
    "general": {
      "title": "基础设置",
      "fields": [
        "enabled",
        "primary_provider"
      ]
    },
    "providers": {
      "title": "CDN提供商配置",
      "fields": [
        "providers.cloudflare",
        "providers.aliyun",
        "providers.tencent"
      ]
    },
    "cache_strategies": {
      "title": "缓存策略",
      "fields": [
        "cache_strategies.static",
        "cache_strategies.images",
        "cache_strategies.html",
        "cache_strategies.api"
      ]
    },
    "auto_optimize": {
      "title": "自动优化",
      "fields": [
        "auto_optimize.convert_to_webp",
        "auto_optimize.compress_images",
        "auto_optimize.compression_quality",
        "auto_optimize.generate_srcset"
      ]
    },
    "url_conversion": {
      "title": "URL转换",
      "fields": [
        "url_conversion.enabled",
        "url_conversion.cdn_base_url",
        "url_conversion.auto_convert_html",
        "url_conversion.excluded_paths"
      ]
    },
    "monitoring": {
      "title": "监控设置",
      "fields": [
        "monitoring.enabled",
        "monitoring.analytics_period",
        "monitoring.auto_purge_on_update"
      ]
    }
  },
  "features": [
    "多云CDN支持 (Cloudflare/阿里云/腾讯云)",
    "智能缓存策略管理",
    "缓存清除和预热",
    "CDN性能分析和监控",
    "HTML URL自动转换",
    "内容更新时自动清除缓存",
    "图片WebP转换支持",
    "响应式图片srcset生成"
  ],
  "api_endpoints": [
    {
      "path": "/api/v2/cloud/cdn/purge",
      "method": "POST",
      "description": "清除CDN缓存"
    },
    {
      "path": "/api/v2/cloud/cdn/prefetch",
      "method": "POST",
      "description": "预热CDN缓存"
    },
    {
      "path": "/api/v2/cloud/cdn/analytics",
      "method": "GET",
      "description": "获取CDN分析数据"
    },
    {
      "path": "/api/v2/cloud/cdn/test",
      "method": "POST",
      "description": "测试CDN连接"
    },
    {
      "path": "/api/v2/cloud/cdn/config",
      "method": "PUT",
      "description": "更新CDN配置"
    }
  ]
}
