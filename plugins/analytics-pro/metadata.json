  "dependencies": [],
  "settings_schema": {
    "enable_tracking": {
      "type": "boolean",
      "label": "启用跟踪",
      "default": true
    },
    "track_anonymous_users": {
      "type": "boolean",
      "label": "跟踪匿名用户",
      "default": true
    },
    "data_retention_days": {
      "type": "number",
      "label": "数据保留天数",
      "default": 90
    },
    "enable_real_time": {
      "type": "boolean",
      "label": "启用实时统计",
      "default": true
    },
    "enable_conversion_tracking": {
      "type": "boolean",
      "label": "启用转化跟踪",
      "default": true
    },
    "dashboard_refresh_interval": {
      "type": "number",
      "label": "仪表盘刷新间隔(秒)",
      "default": 30,
      "min": 10,
      "max": 300
    }
  },
  "changelog": "初始版本发布 - 包含访客统计、热门排行、来源分析、转化漏斗功能",
