{
  "id": 24,
  "name": "联系表单",
  "slug": "contact-forms",
  "version": "1.0.0",
  "description": "可视化表单构建器，提供表单提交管理、邮件通知和反垃圾保护功能",
  "author": "FastBlog Team",
  "author_url": "https://athenavi.github.io",
  "plugin_url": "https://athenavi.github.io/plugins/contact-forms",
  "icon": "📧",
  "category": "forms",
  "rating": 4.6,
  "installs": 0,
  "requires": {
    "fastblog": ">=0.0.3.6",
    "python": ">=3.14.2"
  },
  "dependencies": [],
  "settings_schema": {
    "enable_spam_protection": {
      "type": "boolean",
      "label": "启用反垃圾保护",
      "default": true
    },
    "email_notifications": {
      "type": "boolean",
      "label": "启用邮件通知",
      "default": true
    },
    "notification_email": {
      "type": "text",
      "label": "通知邮箱地址",
      "default": ""
    },
    "auto_reply": {
      "type": "boolean",
      "label": "自动回复",
      "default": true
    },
    "form_fields": {
      "type": "multiselect",
      "label": "表单字段",
      "options": [
        "name",
        "email",
        "phone",
        "subject",
        "message"
      ],
      "default": [
        "name",
        "email",
        "message"
      ]
    }
  },
  "changelog": "初始版本发布 - 包含表单构建、提交管理、邮件通知、反垃圾保护",
  "download_url": "https://athenavi.github.io/plugins/downloads/contact-forms-1.0.0.zip",
  "screenshots": [
    "https://athenavi.github.io/plugins/screenshots/contact-forms-1.png"
  ]
}
