{
  "name": "FastBlog Default",
  "slug": "fastblog-default",
  "version": "1.0.0",
  "description": "FastBlog 默认主题 - 简洁、现代、响应式设计",
  "author": "FastBlog Team",
  "author_url": "https://athenavi.github.io",
  "plugin_url": "https://athenavi.github.io/themes/default",
  "category": "theme",
  "icon": "🎨",
  "screenshot": "screenshot.svg",
  "license": "MIT",
  "tags": [
    "responsive",
    "modern",
    "clean",
    "blog"
  ],
  "requires": {
    "fastblog": ">=1.0.0"
  },
  "supports": [
    "custom-logo",
    "custom-header",
    "featured-image",
    "post-thumbnails",
    "comments",
    "widgets"
  ],
  "settings_schema": {
    "colors": {
      "type": "group",
      "label": "颜色方案",
      "fields": {
        "primary": {"type": "color", "label": "主色调", "default": "#3b82f6"},
        "secondary": {"type": "color", "label": "次要色", "default": "#64748b"},
        "accent": {"type": "color", "label": "强调色", "default": "#f59e0b"},
        "background": {"type": "color", "label": "背景色", "default": "#ffffff"},
        "foreground": {"type": "color", "label": "前景色", "default": "#1f2937"}
      }
    },
    "layout": {
      "type": "group",
      "label": "布局设置",
      "fields": {
        "sidebar_position": {"type": "select", "label": "侧边栏位置", "options": [{"value": "left", "label": "左侧"}, {"value": "right", "label": "右侧"}, {"value": "none", "label": "无"}], "default": "right"},
        "content_width": {"type": "select", "label": "内容宽度", "options": [{"value": "max-w-4xl", "label": "中"}, {"value": "max-w-5xl", "label": "宽"}, {"value": "max-w-7xl", "label": "超宽"}], "default": "max-w-4xl"},
        "show_sidebar": {"type": "boolean", "label": "显示侧边栏", "default": true}
      }
    },
    "typography": {
      "type": "group",
      "label": "排版设置",
      "fields": {
        "font_family": {"type": "text", "label": "字体", "default": "Inter, system-ui, sans-serif"},
        "font_size": {"type": "text", "label": "字号", "default": "16px"},
        "line_height": {"type": "number", "label": "行高", "default": 1.6}
      }
    }
  }
}
