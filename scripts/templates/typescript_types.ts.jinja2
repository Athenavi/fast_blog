/**
 * API 类型定义
 * 由 routes.yaml 自动生成 - 请勿手动修改
 * 生成时间：{{ now() }}
 */

    {% for model_name, model_def in models.items() %}
export interface {{ model_name }} {
    {% for prop_name, prop_def in model_def.get('properties', {}).items() %}
    {{ prop_name }}{% if prop_def is mapping and prop_def.get('nullable') %}?{% endif %}: {% if prop_def is mapping %}{{ prop_def.type|map_ts_type(prop_name) }}{% else %}any
    {% endif %};
    {% endfor %}
}

{% endfor %}

// 通用响应类型
export interface ApiResponse<T = any> {
    success: boolean;
    data?: T;
    error?: string;
    message?: string;
}

// 请求参数类型
{% set endpoints_by_module = endpoints | groupby('module') %}
{% for module_name, module_endpoints in endpoints_by_module %}
{% for endpoint in module_endpoints %}
{% if endpoint.parameters %}
export interface {{ endpoint.handler|capitalize }}Params {
    {% for param in endpoint.parameters %}
    {{ param.name }}{% if not param.required %}?{% endif %}: {{ param.type|map_ts_type(param.name) }};
    {% endfor %}
}
{% endif %}
{% endfor %}
{% endfor %}
