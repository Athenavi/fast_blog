# ==================== 表名前缀配置 ====================
# 注意：如果使用了表名前缀（如 fb_），请在具体模型类的 Meta 中设置 db_table
# 例如：db_table = "{{ table_prefix }}users" (对于 User 模型)
TABLE_PREFIX = "{{ table_prefix }}"


def get_table_name(base_name: str) -> str:
    """
    获取带前缀的表名
    
    Args:
        base_name: 基础表名（不带前缀）
    
    Returns:
        带前缀的完整表名
    """
    if TABLE_PREFIX and not base_name.startswith(TABLE_PREFIX):
        return f"{TABLE_PREFIX}{base_name}"
    return base_name


# ==================== 通用 Mixin 类 ====================

class TimestampMixin(models.Model):
    """时间戳混合类（包含创建和更新时间）"""
    created_at = models.DateTimeField('创建时间', auto_now_add=True)
    updated_at = models.DateTimeField('更新时间', auto_now=True)

    class Meta:
        abstract = True


class SoftDeleteMixin(models.Model):
    """软删除混合类"""
    is_deleted = models.BooleanField('是否删除', default=False)
    deleted_at = models.DateTimeField('删除时间', blank=True, null=True)

    class Meta:
        abstract = True

    def delete(self, using=None, keep_parents=False):
        """重写删除方法为软删除"""
        self.is_deleted = True
        from django.utils import timezone
        self.deleted_at = timezone.now()
        self.save(update_fields=['is_deleted', 'deleted_at'])

