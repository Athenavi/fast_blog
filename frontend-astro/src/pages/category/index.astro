---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CategoryService } from '../../lib/services/category';
import { ArticleService } from '../../lib/services/article';
import type { Category, Article } from '../../lib/types';

// 从 URL 参数获取分类名称
const url = new URL(Astro.request.url);
const name = url.searchParams.get('name');

// 获取分类详情和文章
let category: Category | null = null;
let articles: Article[] = [];
let error: string | null = null;

if (name) {
  try {
    const [categoryRes, articlesRes] = await Promise.all([
      CategoryService.getCategoryByName(name),
      ArticleService.getArticles({ per_page: 20 })
    ]);

    if (categoryRes.success && categoryRes.data) {
      category = categoryRes.data;
    }

    if (articlesRes.success && articlesRes.data) {
      articles = articlesRes.data.data || [];
    }
  } catch (err) {
    error = '加载失败';
    console.error('Failed to fetch category:', err);
  }
} else {
  error = '缺少分类参数';
}
---

<BaseLayout 
  title={category ? `${category.name} - FastBlog` : '分类 - FastBlog'}
  description={category?.description || '浏览分类文章'}
>
  {error || !category ? (
    <div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900">
      <div class="text-center">
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-2">{error || '分类不存在'}</h1>
        <a href="/categories" class="text-blue-600 hover:underline">返回分类列表</a>
      </div>
    </div>
  ) : (
    <div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800">
      <!-- Header -->
      <header class="bg-white dark:bg-gray-800 shadow-sm sticky top-0 z-50">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">
            <a href="/" class="flex items-center gap-2 text-xl font-bold text-blue-600 dark:text-blue-400">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              <span>FastBlog</span>
            </a>

            <nav class="flex items-center gap-6">
              <a href="/" class="text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">首页</a>
              <a href="/articles" class="text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">文章</a>
              <a href="/categories" class="text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">分类</a>
            </nav>
          </div>
        </div>
      </header>

      <!-- Category Header -->
      <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <h1 class="text-4xl font-black text-gray-900 dark:text-white mb-4">{category.name}</h1>
          {category.description && (
            <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">{category.description}</p>
          )}
          <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
            <span>{category.article_count || articles.length} 篇文章</span>
            {category.subscription_count !== undefined && (
              <span>{category.subscription_count} 订阅</span>
            )}
          </div>
        </div>
      </div>

      <!-- Articles List -->
      <main class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {articles.map((article, index) => (
            <article class="animate-fade-in-up group relative bg-white dark:bg-gray-900 rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-all hover:shadow-xl"
                     style={`animation-delay: ${index * 0.05}s`}>
              <a href={`/blog/detail?slug=${article.slug}`} class="block">
                {article.cover_image && (
                  <div class="relative aspect-video overflow-hidden">
                    <img src={article.cover_image} alt={article.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  </div>
                )}

                <div class="p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                    {article.title}
                  </h3>

                  <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 line-clamp-2">
                    {article.excerpt || article.summary || '暂无摘要'}
                  </p>

                  <div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400">
                    <span>{article.created_at ? new Date(article.created_at).toLocaleDateString('zh-CN') : ''}</span>
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                      {article.views || 0}
                    </span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>

        {articles.length === 0 && (
          <div class="text-center py-20">
            <div class="text-6xl mb-4">📝</div>
            <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-2">暂无文章</h2>
            <p class="text-gray-600 dark:text-gray-400">该分类下还没有文章</p>
          </div>
        )}
      </main>
    </div>
  )}
</BaseLayout>
