---
// 404 页面
import Layout from '@/layouts/Layout.astro';
---

<Layout title="404 - 页面未找到">
  <div class="min-h-[80vh] flex flex-col items-center justify-center px-4">
    <h1 class="text-6xl font-bold text-gray-300 dark:text-gray-600 mb-4">404</h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 mb-8">页面未找到</p>
    <a href="/" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
      返回首页
    </a>
  </div>
</Layout>
