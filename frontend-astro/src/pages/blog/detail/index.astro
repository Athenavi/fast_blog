---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ArticleService } from '../../../lib/services/article';
import type { Article } from '../../../lib/types';

// 从 URL 参数获取 slug
const url = new URL(Astro.request.url);
const slug = url.searchParams.get('slug');

// 获取文章详情
let article: Article | null = null;
let error: string | null = null;

if (slug) {
  try {
    const response = await ArticleService.getArticleBySlug(slug);
    
    if (response.success && response.data) {
      article = response.data;
    } else {
      error = response.error || '文章不存在';
    }
  } catch (err) {
    error = '加载失败，请稍后重试';
    console.error('Failed to fetch article:', err);
  }
} else {
  error = '缺少文章参数';
}
---

<BaseLayout 
  title={article ? `${article.title} - FastBlog` : '文章详情 - FastBlog'}
  description={article?.excerpt || article?.summary || '阅读精彩文章'}
>
  {error || !article ? (
    <div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900">
      <div class="text-center">
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-2">{error || '文章不存在'}</h1>
        <a href="/articles" class="text-blue-600 hover:underline">返回文章列表</a>
      </div>
    </div>
  ) : (
    <article class="min-h-screen bg-white dark:bg-gray-950">
      <!-- Header -->
      <header class="bg-white dark:bg-gray-800 shadow-sm sticky top-0 z-50">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">
            <a href="/" class="flex items-center gap-2 text-xl font-bold text-blue-600 dark:text-blue-400">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              <span>FastBlog</span>
            </a>

            <nav class="flex items-center gap-6">
              <a href="/" class="text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">首页</a>
              <a href="/articles" class="text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">文章</a>
              <a href="/categories" class="text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">分类</a>
            </nav>
          </div>
        </div>
      </header>

      <!-- Article Content -->
      <main class="container mx-auto px-4 sm:px-6 lg:px-8 py-12 max-w-4xl">
        <!-- Article Header -->
        <div class="mb-8">
          {article.category && (
            <a href={`/category?name=${article.category.slug || article.category.name}`} class="inline-block px-3 py-1 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-sm font-medium rounded-full mb-4 hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">
              {article.category.name}
            </a>
          )}

          <h1 class="text-4xl sm:text-5xl font-black text-gray-900 dark:text-white mb-6 leading-tight">
            {article.title}
          </h1>

          <div class="flex items-center gap-6 text-sm text-gray-500 dark:text-gray-400">
            {article.author && (
              <div class="flex items-center gap-2">
                {article.author.avatar ? (
                  <img src={article.author.avatar} alt={article.author.username} class="w-8 h-8 rounded-full" />
                ) : (
                  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white font-bold">
                    {article.author.username.charAt(0).toUpperCase()}
                  </div>
                )}
                <span>{article.author.username}</span>
              </div>
            )}

            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {article.published_at ? new Date(article.published_at).toLocaleDateString('zh-CN') : ''}
            </span>

            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              {article.views || 0} 阅读
            </span>

            {article.likes !== undefined && (
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
                {article.likes} 点赞
              </span>
            )}
          </div>
        </div>

        <!-- Cover Image -->
        {article.cover_image && (
          <div class="relative aspect-video rounded-2xl overflow-hidden mb-8">
            <img src={article.cover_image} alt={article.title} class="w-full h-full object-cover" loading="lazy" />
          </div>
        )}

        <!-- Tags -->
        {article.tags && article.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {article.tags.map(tag => (
              <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-sm rounded-full">
                #{tag}
              </span>
            ))}
          </div>
        )}

        <!-- Article Body -->
        <div class="prose prose-lg dark:prose-invert max-w-none">
          <div set:html={article.content || '<p>暂无内容</p>'}></div>
        </div>

        <!-- Share & Actions -->
        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <button class="flex items-center gap-2 px-4 py-2 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
                <span>点赞</span>
              </button>

              <button class="flex items-center gap-2 px-4 py-2 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-5.367 3 3 0 00-5.367 5.367zm0 0L9 12" />
                </svg>
                <span>分享</span>
              </button>
            </div>

            <a href="/articles" class="text-blue-600 dark:text-blue-400 hover:underline">
              ← 返回文章列表
            </a>
          </div>
        </div>

        <!-- Comment Section Placeholder -->
        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">评论</h2>
          <div class="text-center py-12 text-gray-500 dark:text-gray-400">
            <p>评论区即将推出...</p>
          </div>
        </div>
      </main>
    </article>
  )}
</BaseLayout>

<style>
  .prose h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #111827;
  }
  
  .dark .prose h2 {
    color: #fff;
  }
  
  .prose h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #111827;
  }
  
  .dark .prose h3 {
    color: #fff;
  }
  
  .prose p {
    margin-bottom: 1rem;
    line-height: 1.625;
  }
  
  .prose a {
    color: #2563eb;
  }
  
  .dark .prose a {
    color: #60a5fa;
  }
  
  .prose a:hover {
    text-decoration: underline;
  }
  
  .prose img {
    border-radius: 0.5rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .prose blockquote {
    border-left: 4px solid #d1d5db;
    padding-left: 1rem;
    font-style: italic;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .dark .prose blockquote {
    border-left-color: #374151;
  }
  
  .prose code {
    background-color: #f3f4f6;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }
  
  .dark .prose code {
    background-color: #1f2937;
  }
  
  .prose pre {
    background-color: #111827;
    color: #f3f4f6;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .prose ul, .prose ol {
    margin-bottom: 1rem;
    margin-left: 1.5rem;
  }
  
  .prose li {
    margin-bottom: 0.5rem;
  }
</style>
