---
// 文章详情页 - 静态模式，纯客户端渲染
import Layout from '@/layouts/Layout.astro';
import ArticleDetail from '@/components/pages/ArticleDetail';
---

<Layout title="文章详情 - FastBlog">
    <main class="max-w-full py-8 pt-20">
    {/* 使用 client:only 确保完全在客户端渲染 */}
    <ArticleDetail client:only="react"/>
  </main>
</Layout>

<style>
  .prose h2 { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; color: #111827; }
  .dark .prose h2 { color: #fff; }
  .prose h3 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; color: #111827; }
  .dark .prose h3 { color: #fff; }
  .prose p { margin-bottom: 1rem; line-height: 1.625; }
  .prose a { color: #2563eb; }
  .dark .prose a { color: #60a5fa; }
  .prose a:hover { text-decoration: underline; }
  .prose img { border-radius: 0.5rem; margin: 1.5rem 0; }
  .prose blockquote { border-left: 4px solid #d1d5db; padding-left: 1rem; font-style: italic; margin: 1.5rem 0; }
  .dark .prose blockquote { border-left-color: #374151; }
  .prose code { background-color: #f3f4f6; padding: 0.25rem 0.5rem; border-radius: 0.25rem; font-size: 0.875rem; }
  .dark .prose code { background-color: #1f2937; }
  .prose pre { background-color: #111827; color: #f3f4f6; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 1.5rem 0; }
  .prose ul, .prose ol { margin-bottom: 1rem; margin-left: 1.5rem; }
  .prose li { margin-bottom: 0.5rem; }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
  .prose th, .prose td { border: 1px solid #d1d5db; padding: 0.5rem 1rem; text-align: left; }
  .dark .prose th, .dark .prose td { border-color: #374151; }
</style>
