---
// 文章详情页 - 服务端渲染 + 客户端水合
import Layout from '@/layouts/Layout.astro';
import {apiClient} from '@/lib/api/base-client';
import type {Article} from '@/lib/api/base-types';

export async function getStaticPaths() {
  return [];
}

const {slug = ''} = Astro.params;
const querySlug = Astro.url.searchParams.get('slug') || slug;

// 尝试服务端获取数据
let article: Article | null = null;
let fetchError: string | null = null;

if (querySlug) {
  try {
      const apiUrl = `/articles/p/${querySlug}`;
      console.log(`[Blog Detail] Fetching article from: ${apiUrl}`);
      const res = await apiClient.get(apiUrl);
      console.log('[Blog Detail] API response success:', res.success);
    if (res.success && res.data) {
      const d = res.data as any;
      article = d.article || d;
        console.log('[Blog Detail] Article loaded:', article?.title);
    } else {
      fetchError = res.error || '文章不存在';
        console.error('[Blog Detail] API returned error:', fetchError, 'Response:', JSON.stringify(res));
    }
  } catch (err) {
    fetchError = '加载失败';
      console.error('[Blog Detail] Exception:', err);
  }
} else {
    console.log('[Blog Detail] No slug provided, querySlug is empty');
}
---

<Layout title={article ? `${article.title} - FastBlog` : '文章详情 - FastBlog'}>
    <!-- Debug Info (remove in production) -->
    <div class="fixed top-4 right-4 bg-yellow-100 dark:bg-yellow-900 p-4 rounded-lg text-xs z-50 max-w-md">
        <p><strong>Debug Info:</strong></p>
        <p>querySlug: {querySlug || '(empty)'}</p>
        <p>article: {article ? article.title : '(null)'}</p>
        <p>fetchError: {fetchError || '(none)'}</p>
    </div>

    {
    article ? (
      <article class="min-h-screen bg-white dark:bg-gray-950 pt-20">
        <main class="container mx-auto px-4 sm:px-6 lg:px-8 py-12 max-w-4xl">
          <!-- Category -->
          {article.category && (
            <a href={`/articles?category_id=${article.category.id}`} class="inline-block px-3 py-1 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-sm font-medium rounded-full mb-4 hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">
              {article.category.name}
            </a>
          )}

          <h1 class="text-4xl sm:text-5xl font-black text-gray-900 dark:text-white mb-6 leading-tight">{article.title}</h1>

          <div class="flex flex-wrap items-center gap-6 text-sm text-gray-500 dark:text-gray-400 mb-8">
            {article.author && (
              <span class="flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white text-xs font-bold">
                  {article.author.username?.charAt(0)?.toUpperCase() || 'U'}
                </span>
                {article.author.username}
              </span>
            )}
            <span>{article.created_at ? new Date(article.created_at).toLocaleDateString('zh-CN') : ''}</span>
            <span>{article.views || article.views_count || 0} 阅读</span>
            <span>{article.likes || 0} 点赞</span>
          </div>

          {article.cover_image && (
            <div class="relative aspect-video rounded-2xl overflow-hidden mb-8">
              <img src={article.cover_image} alt={article.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
          )}

          {article.tags && article.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-8">
              {article.tags.map((tag: string) => (
                <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-sm rounded-full">#{tag}</span>
              ))}
            </div>
          )}

          <div class="prose prose-lg dark:prose-invert max-w-none">
            <div set:html={article.content || '<p>暂无内容</p>'}></div>
          </div>

          <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 text-center">
            <a href="/articles" class="text-blue-600 dark:text-blue-400 hover:underline">← 返回文章列表</a>
          </div>
        </main>
      </article>
    ) : (
      <div class="min-h-screen flex items-center justify-center">
        <div class="text-center">
          <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-2">{fetchError || '文章不存在'}</h1>
          <a href="/articles" class="text-blue-600 hover:underline">返回文章列表</a>
        </div>
      </div>
    )
  }
</Layout>

<style>
  .prose h2 { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; color: #111827; }
  .dark .prose h2 { color: #fff; }
  .prose h3 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; color: #111827; }
  .dark .prose h3 { color: #fff; }
  .prose p { margin-bottom: 1rem; line-height: 1.625; }
  .prose a { color: #2563eb; }
  .dark .prose a { color: #60a5fa; }
  .prose a:hover { text-decoration: underline; }
  .prose img { border-radius: 0.5rem; margin: 1.5rem 0; }
  .prose blockquote { border-left: 4px solid #d1d5db; padding-left: 1rem; font-style: italic; margin: 1.5rem 0; }
  .dark .prose blockquote { border-left-color: #374151; }
  .prose code { background-color: #f3f4f6; padding: 0.25rem 0.5rem; border-radius: 0.25rem; font-size: 0.875rem; }
  .dark .prose code { background-color: #1f2937; }
  .prose pre { background-color: #111827; color: #f3f4f6; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 1.5rem 0; }
  .prose ul, .prose ol { margin-bottom: 1rem; margin-left: 1.5rem; }
  .prose li { margin-bottom: 0.5rem; }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
  .prose th, .prose td { border: 1px solid #d1d5db; padding: 0.5rem 1rem; text-align: left; }
  .dark .prose th, .dark .prose td { border-color: #374151; }
</style>
