# ============================================================================
# FastBlog 环境配置文件
# ============================================================================
# 说明：复制此文件为 .env 并根据实际情况修改配置项
# 注意：生产环境请务必修改所有默认密码和密钥

# ----------------------------------------------------------------------------
# 数据库配置（仅支持 PostgreSQL）
# ----------------------------------------------------------------------------
DB_ENGINE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=fast_blog
DB_TABLE_PREFIX=fb_

# 数据库连接池配置
DB_POOL_SIZE=20
DB_POOL_OVERFLOW=30
DB_POOL_TIMEOUT=60

# ----------------------------------------------------------------------------
# 应用配置
# ----------------------------------------------------------------------------
DOMAIN=http://localhost:9421
TITLE=FastBlog
SECRET_KEY=your-secret-key-change-in-production
TIME_ZONE=Asia/Shanghai
ENVIRONMENT=development
DEBUG=True

# JWT 配置
JWT_EXPIRATION_DELTA=86400
REFRESH_TOKEN_EXPIRATION_DELTA=604800
JWT_SECRET_KEY=your-jwt-secret-key

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 邮件配置
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=

# 存储配置
UPLOAD_LIMIT=62914560
USER_FREE_STORAGE_LIMIT=536870912

# S3存储配置（从0.3.6.5版本后为必选）
S3_ENABLED=True
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_USE_SSL=True
S3_SIGNATURE_VERSION=s3v4

# 备案信息
BEIAN=京ICP备12345678号