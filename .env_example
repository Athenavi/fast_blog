# ============================================================================
# FastBlog 环境配置文件
# ============================================================================
# 说明：复制此文件为 .env 并根据实际情况修改配置项
# 注意：生产环境请务必修改所有默认密码和密钥
#
# 快速开始：
# 1. cp .env_example .env
# 2. 修改下面的配置项
# 3. 启动应用: python main.py

# ----------------------------------------------------------------------------
# 数据库配置（仅支持 PostgreSQL）
# ----------------------------------------------------------------------------
# PostgreSQL 连接信息
DB_ENGINE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here  # ⚠️ 生产环境必须修改
DB_NAME=fast_blog
DB_TABLE_PREFIX=fb_

# 数据库连接池配置
# 建议值：pool_size = CPU核心数 * 2, max_overflow = pool_size * 1.5
DB_POOL_SIZE=20
DB_POOL_OVERFLOW=30
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=1800  # 连接回收时间（秒）

# ----------------------------------------------------------------------------
# 应用配置
# ----------------------------------------------------------------------------
# 服务器地址
DOMAIN=http://localhost:9421  # 生产环境改为 https://yourdomain.com

# 站点信息
TITLE=FastBlog
DESCRIPTION=A modern, fast blog platform
KEYWORDS=blog, fast, modern

# 安全配置
SECRET_KEY=your-secret-key-change-in-production  # ⚠️ 生产环境必须修改（至少32字符）
TIME_ZONE=Asia/Shanghai
ENVIRONMENT=development  # development | production | testing
DEBUG=True  # ⚠️ 生产环境必须设为 False

# JWT 认证配置
JWT_EXPIRATION_DELTA=86400  # Access Token 过期时间（秒）- 默认24小时
REFRESH_TOKEN_EXPIRATION_DELTA=604800  # Refresh Token 过期时间（秒）- 默认7天
JWT_SECRET_KEY=your-jwt-secret-key  # ⚠️ 生产环境必须修改
JWT_ALGORITHM=HS256

# ----------------------------------------------------------------------------
# Redis 配置（缓存和会话存储）
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # 如果有密码，请填写
REDIS_MAX_CONNECTIONS=50

# 缓存 TTL 配置（秒）
CACHE_TTL_DEFAULT=600  # 默认缓存时间 - 10分钟
CACHE_TTL_ARTICLES=3600  # 文章缓存 - 1小时
CACHE_TTL_USERS=1800  # 用户信息缓存 - 30分钟

# ----------------------------------------------------------------------------
# 邮件配置（用于密码重置、通知等）
# ----------------------------------------------------------------------------
# Gmail 示例
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password  # Gmail 需要使用应用专用密码

# QQ 邮箱示例
# MAIL_SERVER=smtp.qq.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your_qq@qq.com
# MAIL_PASSWORD=your_authorization_code

# 163 邮箱示例
# MAIL_SERVER=smtp.163.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your_163@163.com
# MAIL_PASSWORD=your_authorization_code

MAIL_FROM=noreply@fastblog.com  # 发件人地址
MAIL_FROM_NAME=FastBlog  # 发件人名称

# ----------------------------------------------------------------------------
# 文件存储配置
# ----------------------------------------------------------------------------
# 上传限制
UPLOAD_LIMIT=62914560  # 单个文件最大大小 - 60MB
USER_FREE_STORAGE_LIMIT=536870912  # 免费用户存储限额 - 512MB

# FFmpeg 配置（视频处理）
# Windows: 下载 ffmpeg.exe 并设置路径，例如: C:/ffmpeg/bin/ffmpeg.exe
# Linux: sudo apt-get install ffmpeg (通常已经在 PATH 中)
# macOS: brew install ffmpeg (通常已经在 PATH 中)
FFMPEG_PATH=ffmpeg  # 如果 ffmpeg 在 PATH 中，直接填 ffmpeg；否则填写完整路径
FFPROBE_PATH=ffprobe  # ffprobe 路径，通常与 ffmpeg 在同一目录

# S3/对象存储配置（从0.3.6.5版本后为必选）
# 支持的提供商：AWS S3, Cloudflare R2, DigitalOcean Spaces, MinIO 等
S3_ENABLED=True
S3_ENDPOINT_URL=  # AWS S3 留空，其他提供商填写 endpoint
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=fastblog-media
S3_REGION=us-east-1
S3_USE_SSL=True
S3_SIGNATURE_VERSION=s3v4

# CDN 配置（可选）
CDN_ENABLED=False
CDN_URL=https://cdn.yourdomain.com

# ----------------------------------------------------------------------------
# 备案信息（中国大陆服务器必填）
# ----------------------------------------------------------------------------
BEIAN=京ICP备12345678号
BEIAN_LINK=https://beian.miit.gov.cn/

# ----------------------------------------------------------------------------
# CORS 配置
# ----------------------------------------------------------------------------
# 允许的前端域名（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# 生产环境示例：
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ----------------------------------------------------------------------------
# 日志配置
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=logs
LOG_MAX_BYTES=5242880  # 单个日志文件最大大小 - 5MB
LOG_BACKUP_COUNT=3  # 保留的备份文件数量

# ----------------------------------------------------------------------------
# 性能优化配置
# ----------------------------------------------------------------------------
# 文章列表每页默认数量
ARTICLES_PER_PAGE=10

# 搜索结果每页数量
SEARCH_RESULTS_PER_PAGE=20

# 评论每页数量
COMMENTS_PER_PAGE=50

# API 速率限制
RATE_LIMIT_REQUESTS=100  # 每分钟最大请求数
RATE_LIMIT_WINDOW=60  # 时间窗口（秒）

# ----------------------------------------------------------------------------
# SEO 配置
# ----------------------------------------------------------------------------
# Google Analytics
GOOGLE_ANALYTICS_ID=  # G-XXXXXXXXXX

# Google Search Console
GOOGLE_SITE_VERIFICATION=  # 验证代码

# Baidu Analytics
BAIDU_ANALYTICS_ID=  # UM-XXXXXXXX-X

# Social Media
FACEBOOK_APP_ID=
TWITTER_CARD_TYPE=summary_large_image

# ----------------------------------------------------------------------------
# 第三方服务集成
# ----------------------------------------------------------------------------
# Sentry 错误追踪
SENTRY_DSN=  # https://xxx@sentry.io/xxx
SENTRY_TRACES_SAMPLE_RATE=1.0

# OpenAI API（AI 功能）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Slack 通知
SLACK_WEBHOOK_URL=  # https://hooks.slack.com/services/XXX

# Discord 通知
DISCORD_WEBHOOK_URL=  # https://discord.com/api/webhooks/XXX

# SendGrid 邮件服务
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com

# Mailgun 邮件服务
MAILGUN_API_KEY=
MAILGUN_DOMAIN=example.com
MAILGUN_FROM_EMAIL=noreply@example.com

# SMTP 邮件服务
EMAIL_SMTP_SERVER=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=user@example.com
EMAIL_PASSWORD=password
EMAIL_FROM=noreply@example.com
EMAIL_TO=admin@example.com,editor@example.com

# Stripe 支付
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal 支付
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox  # sandbox | live

# ----------------------------------------------------------------------------
# 开发工具配置
# ----------------------------------------------------------------------------
# Swagger UI 配置
SWAGGER_UI_ENABLED=True
SWAGGER_UI_PATH=/docs

# ReDoc 配置
REDOC_ENABLED=True
REDOC_PATH=/redoc

# ----------------------------------------------------------------------------
# 其他配置
# ----------------------------------------------------------------------------
# 是否启用注册
ALLOW_REGISTRATION=True

# 是否需要邮箱验证
EMAIL_VERIFICATION_REQUIRED=False

# 默认语言
DEFAULT_LOCALE=zh_CN

# 支持的语言列表（逗号分隔）
SUPPORTED_LOCALES=zh_CN,en_US,ja_JP,ko_KR

# 维护模式
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=网站正在维护中，请稍后访问