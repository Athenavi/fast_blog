# ============================================================================
# Docker-specific: Exclude directories NOT needed by the backend at runtime
# (These are either volume-mounted, separate containers, or not used)
# ============================================================================

# Frontend source (served by separate nginx container)
frontend-astro

# User data directories (volume-mounted at runtime)
media
uploads
upload_chunks
backups

# Nginx config (separate nginx container)
nginx

# Mobile app source
mobile-app

# SDK & Scripts (not imported by backend)
sdk
scripts

# Advanced adapter (not imported anywhere in src/)
advanced

# Generated apps (not imported, legacy Django code)
apps/generated

# Update server/updater (not imported by backend)
update_server
updater

# Runtime generated data (not needed in image)
static_generated
plugins_data
custom-patterns

# Build/release directories
debug
release
storage

# CI/CD
pre-commit-config.yaml
.qoderignore

# Lock files (not needed for Python backend)
package-lock.json

# Test plugin system script
test_plugin_system.py

# Startup scripts (not needed inside container)
start-meilisearch.bat
start-meilisearch.sh
install.bat
install.sh

# Pyproject/pytest configs (not needed at runtime)
pyproject.toml
pytest.ini
