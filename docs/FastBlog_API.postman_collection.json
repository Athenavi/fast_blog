{
  "info": {
    "name": "FastBlog API",
    "description": "FastBlog 博客系统完整 API 集合\n\n包含所有核心功能的 API 端点，支持文章管理、用户认证、媒体上传等功能。\n\n**认证方式**: Bearer Token (JWT)\n\n**Base URL**: http://localhost:9421/api/v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:9421/api/v1",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 认证 Auth",
      "item": [
        {
          "name": "登录 Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin@example.com\",\n  \"password\": \"your_password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "使用用户名/邮箱和密码登录，获取 JWT Token。\n\nToken 有效期: 1小时"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.access_token) {",
                  "        pm.collectionVariables.set('access_token', jsonData.access_token);",
                  "        console.log('Token saved:', jsonData.access_token.substring(0, 20) + '...');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "刷新 Token Refresh",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          }
        },
        {
          "name": "登出 Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "📝 文章 Articles",
      "item": [
        {
          "name": "获取文章列表 List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/articles?page=1&per_page=10&order_by=created_at&order=desc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "articles"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "10"
                },
                {
                  "key": "order_by",
                  "value": "created_at"
                },
                {
                  "key": "order",
                  "value": "desc"
                },
                {
                  "key": "category_id",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "获取文章详情 Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/articles/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "articles",
                "1"
              ]
            }
          }
        },
        {
          "name": "创建文章 Create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"我的第一篇文章\",\n  \"slug\": \"my-first-article\",\n  \"excerpt\": \"这是文章的简短描述...\",\n  \"content\": \"# 标题\\n\\n这是文章内容，支持 **Markdown** 语法。\",\n  \"category_id\": 1,\n  \"tags\": [\"Python\", \"教程\"],\n  \"cover_image\": \"/media/covers/example.jpg\",\n  \"status\": \"draft\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/articles",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "articles"
              ]
            }
          }
        },
        {
          "name": "更新文章 Update",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"更新后的标题\",\n  \"content\": \"更新后的内容...\",\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/articles/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "articles",
                "1"
              ]
            }
          }
        },
        {
          "name": "删除文章 Delete",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/articles/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "articles",
                "1"
              ]
            }
          }
        }
      ]
    },
