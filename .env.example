# ============================================================================
# FastBlog Environment Configuration
# ============================================================================
# Copy this file to .env and modify the values
# cp .env.example .env
#
# ⚠️  IMPORTANT: Change ALL default passwords and secret keys in production!
# ============================================================================

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
DB_ENGINE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=fast_blog
DB_TABLE_PREFIX=fb_

# Connection pool settings
DB_POOL_SIZE=20
DB_POOL_OVERFLOW=30
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=1800

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
DOMAIN=http://localhost:9421
TITLE=FastBlog
DESCRIPTION=A modern, fast blog platform
KEYWORDS=blog,fast,modern

# Security
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars
TIME_ZONE=Asia/Shanghai
ENVIRONMENT=development
DEBUG=True

# JWT Authentication
JWT_EXPIRATION_DELTA=86400
REFRESH_TOKEN_EXPIRATION_DELTA=604800
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ALGORITHM=HS256

# ----------------------------------------------------------------------------
# Redis (Cache & Sessions)
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# Cache TTL (seconds)
CACHE_TTL_DEFAULT=600
CACHE_TTL_ARTICLES=3600
CACHE_TTL_USERS=1800

# ----------------------------------------------------------------------------
# Email
# ----------------------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@fastblog.com
MAIL_FROM_NAME=FastBlog

# ----------------------------------------------------------------------------
# File Storage
# ----------------------------------------------------------------------------
UPLOAD_LIMIT=62914560
USER_FREE_STORAGE_LIMIT=536870912

# S3-compatible storage (optional)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=

# ----------------------------------------------------------------------------
# Search (Meilisearch - optional)
# ----------------------------------------------------------------------------
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=your_master_key

# ----------------------------------------------------------------------------
# Error Tracking (Sentry - optional)
# ----------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn

# ----------------------------------------------------------------------------
# Frontend
# ----------------------------------------------------------------------------
FRONTEND_PORT=4321
BACKEND_PORT=9421
